$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 {
  coords 6413.37 0 4278.188
  m_sTitle "I. Situation"
  m_sTextData "Enemy dismounted Russian Motor Rifles, company-strength, deployed in defensive positions on MSR between Levie and Provins."\
  ""\
  "We are tasked with seizing the central checkpoint (Obj. Apollo) in order to enable follow on forces to secure Provins and Montignac."
  m_aVisibleForFactions {
   "RHS_USAF"
  }
  m_iOrder 1
 }
 {
  coords 6400.072 -0 4274.119
  m_sTitle "II. Enemy Forces"
  m_sTextData "Company-strength dismounted Russian motor rifles deployed in defensive positions along the approach to Provins. Platoons deployed to northern farm, southern woods, and Obj. Apollo, with smaller squads manning checkpoints on MSRs in the AO."\
  ""\
  "Wearing Flora, equipped with modern Russian weaponry."
  m_aVisibleForFactions {
   "RHS_USAF"
  }
  m_iOrder 2
 }
 {
  coords 6394.74 0 4272.332
  m_sTitle "III. Friendly Forces"
  m_sTextData "Platoon-strength USMC rifles assembled at Levie. 1x M2-armed HMMWV and 4x M923A1 trucks available for transport."\
  ""\
  "Wearing woodland MARPAT, equipped with modern US weaponry."
  m_aVisibleForFactions {
   "RHS_USAF"
  }
  m_iOrder 3
 }
 {
  coords 6391.393 -0 4276.19
  m_sTitle "IV. Mission"
  m_sTextData "Secure objective Apollo within the next 60 minutes."
  m_aVisibleForFactions {
   "RHS_USAF"
  }
  m_iOrder 4
 }
}