 {
  coords 5529.117 240.931 9655.396
  m_sTitle "I. Situation"
  m_sTextData "Our motor rifle recon element has occupied a roadside compound on an MSR and is holding it prior to the arrival of our main force."\
  ""\
  "US marines are occupying the area to our south and we believe an attack on our position may come shortly."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 1
 }
 {
