  m_sTitle "II. Friendly Forces"
  m_sTextData "Platoon-strength Russian motor rifles (truck transport) with BRDM escort located on the MSR."\
  ""\
  "Wearing flora."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 2
 }
 {
  coords 5540.01 240.599 9650.655
  m_sTitle "III. Enemy Forces"
  m_sTextData "USMC Rifle platoon with attached weapons and mortar squads in the woods to our south-east."\
  ""\
  "Wearing woodland MARPAT."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 3
 }
 {
  coords 5537.46 240.683 9649.742
  m_sTitle "IV. Mission"
  m_sTextData "Conduct a hasty defense of the marked compound against any US attack for 60 minutes after setup."\
  ""\
  "In the event the position is untenable, withdraw to the north (048 122) before sustaining 80% casualties to prevent a major defeat."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 4
 }
