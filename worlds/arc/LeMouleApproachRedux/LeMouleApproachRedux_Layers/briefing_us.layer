$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 {
  coords 2199.777 0 4441.568
  m_sTitle "I. Situation"
  m_sTextData "Platoon-strength VDV occupying Obj. Hermes, a sawmill on the road to Le Moule. Expected blocking action until arrival of MSV reinforcements within the hour."\
  ""\
  "We are tasked with securing Obj. Hermes in order to allow follow-on forces to assault Le Moule."
  m_aVisibleForFactions {
   "US"
  }
  m_iOrder 1
 }
 {
  coords 2201.465 -0 4429.999
  m_sTitle "II. Enemy Forces"
  m_sTextData "Platoon-strength VDV currently deployed at Obj. Hermes."\
  ""\
  "Additional platoon located at the farm north of Obj. Hermes, likely providing flank security. May reinforce the sawmill if attacked."\
  ""\
  "Wearing Flora, equipped with modern Russian weaponry."
  m_aVisibleForFactions {
   "US"
  }
  m_iOrder 2
 }
 {
  coords 2191.497 0 4436.2
  m_sTitle "III. Friendly Forces"
  m_sTextData "Platoon-strength US Army rifles assembled east of Richemont."\
  ""\
  "Wearing BDUs, equipped with modern American weaponry."
  m_aVisibleForFactions {
   "US"
  }
  m_iOrder 3
 }
 {
  coords 2236.795 0 4405.591
  m_sTitle "IV. Mission"
  m_sTextData "Assault and secure Obj. Hermes within 45 minutes. Occupy the objective uncontested for 1 minute."
  m_aVisibleForFactions {
   "US"
  }
  m_iOrder 4
 }
}