  coords 7162.79 17.844 2852.156
  m_sTitle "Overview"
  m_sTextData "Somewhere in Syria, rebels conduct a delaying action while Russians attempt to push them back, deeper into the city."\
  ""\
  "Mission created by Gabe"
  m_bEmptyFactionVisibility 1
  m_iOrder 0
 }
