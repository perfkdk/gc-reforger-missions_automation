 MissionNotes {
  coords 1593.151 69.314 6971.945
  m_sTitle "IV. Mission"
  m_sTextData "Seize the two marked bridges."\
  ""\
  "Complete this within 60 minutes after setup."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 4
 }
 Situation_R {
  coords 1599.148 69.429 6984.259
  m_sTitle "I. Situation"
  m_sTextData "The local government has been having issues with the American forces in the area and have hired us to secure two bridges to the east of the town. "\
  ""\
  "They are hostile to the company."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 1
 }
 En_R {
  coords 1598.893 69.753 6978.412
  m_sTitle "III. Enemy Forces"
  m_sTextData "1x USMC LAR platoon with LAV-25s and x1 motorized rifle platoon(-)."\
  ""\
  "Equipped with M27, M4A1, MAAWs, Javelins, and FPV drones. wearing desert MARPAT."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 3
 }
 Fr_R {
  coords 1592.659 69.175 6977.795
  m_sTitle "II. Friendly Forces"
  m_sTextData "Company strength Varan Group located to the SW of the objectives."\
  ""\
  "We have x3 platoons. "\
  ""\
  "Our local suppliers were able to provide x2 BMP1Ps, x1 RWS PKM Tigr, x1 RWS KORD Tigr, x1 open top AGS, x1 open to KORD, x1 VDV Typhoon with 30mm RWS, and x2 BTR70s."\
  ""\
  "We also have x1 EW jammer bag, x2 ISR FPV quads, and x8 RPG FPV quads. Plus a command station with batteries and extra headsets/controller. "\
  ""\
  "The range is limited for the drones so it's advisable to load them into a vehicle."\
  ""\
  "Wearing a mixture of camouflage patterns, equipped with Russian weaponry such as AK-74s, PKMs and SVDs."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 2
 }
}