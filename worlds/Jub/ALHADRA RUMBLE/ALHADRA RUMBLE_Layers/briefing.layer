$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 Overview {
  coords 1525.183 68.639 6936.969
  m_sTitle "Overview"
  m_sTextData "The year is 2025. In a remote desert sector, USMC forces have moved to secure a pair of critical transit bridges spanning a river. The sector is heavily occupied by the \"Varan Group,\" a heavily armed Russian Private Military Company operating under a shadow contract. "\
  ""\
  "Varan Group has deployed a full company-sized element, supported by localized Electronic Warfare (EW) and a dense swarm of FPV drones, to seize the crossings and crush the Marine presence."\
  ""\
  "5 minute setup, 60 minute TL after setup"\
  ""\
  "USMC mission CO is the LAR | Varan Group(AFRF) CO is Coy"\
  ""\
  "RU restricted to their spawn during setup."
  m_bEmptyFactionVisibility 1
  m_bShowForAnyFaction 1
 }
 Mish_notes {
  coords 1512.883 67.596 6922.836
  m_sTitle "Mission Notes"
  m_sTextData "End conditions:"\
  ""\
  "90% USMC casualties or both bridges captured: Varan Group Victory"\
  "90% Varan Group(AFRF) casualties or 60 minutes pass: USMC victory"\
  ""\
  "Capzones around the two bridges marked with circles on the map, requires 90% Varan Group(AFRF) control for 1 minute. The radius is 500m."\
  ""\
  "Varan Group restricted to their spawn for 5 minutes"
  m_bEmptyFactionVisibility 1
  m_bShowForAnyFaction 1
  m_iOrder 5
 }
 DroneNotes {
  coords 1512.883 67.596 6922.836
  m_sTitle "Drone Notes"
  m_sTextData "The drones/equipment are located inside a box near the starting point."\
  ""\
  "Setup & Deployment: Procure a drone, controller, FPV goggles, and batteries. Equip the controller in your hands and the goggles on your head. Deploy the drone to the ground and establish a connection."\
  "____________________________________________________________________________"\
  "Signal Management: Connection stability requires proximity and a clear line of sight. Physical obstructions or excessive distance will result in video degradation and severe input latency."\
  "____________________________________________________________________________"\
  "Electronic Warfare: Enemy jamming equipment (backpacks or vehicles) creates localized signal deadzones. Entering these zones or losing line of sight completely will sever your connection and eject you from the feed."\
  ""\
  "Man-Portable Jammers: While the mod developer has not published the exact hardcoded distances, backpack jammers typically create an interference bubble of roughly 100 to 300 meters. You will start seeing video degradation at the edge of this zone before experiencing a complete disconnect closer to the center."\
  ""\
  "Vehicle Jammers: Dedicated electronic warfare vehicles project a much stronger signal. You can expect these platforms to disrupt drone operations from 500 meters to 1,000 meters away."\
  ""\
  "Compounding Factors: The effective jamming distance is heavily influenced by your baseline connection. If you are already flying near your maximum operational range or navigating behind heavy terrain, the jammer will overpower your signal much earlier than if you had a strong, direct line of sight."\
  ""\
  "++++++NOTE: JAMMING WORKS ON YOUR OWN DRONES+++++++"\
  "____________________________________________________________________________"\
  "Combat Operations: For kamikaze strikes, arm the warhead (L3 on controller / Z on keyboard) prior to impact. Manually disconnect at any time using Backspace."\
  "____________________________________________________________________________"\
  "Hardware Upgrades: Utilize drone antennas to multiply operational range by 5x, or deploy command stations to operate up to three drones simultaneously."
  m_bEmptyFactionVisibility 1
  m_bShowForAnyFaction 1
  m_iOrder 8
 }
 JavNotes {
  coords 1512.883 67.596 6922.836
  m_sTitle "Jav Notes"
  m_sTextData "My apologies to those who said they were broken the first playthrough and I disregarded it. There is a bug where you must drop the JAV and pick it back up prior to firing."\
  ""\
  "Unless it is placed in the world on spawn. Which the ones in this mission are. They are located inside the drone box."\
  ""\
  "The Jav was added by WCS_Armaments."\
  ""\
  "It's use is exactly like the stinger."\
  ""\
  "Get line of sight of a target, hold left ctrl until you hear a tone, then fire."\
  ""\
  "It is F&F and doesn't have a reload."\
  ""\
  "It will fire without a target lock so don't ND."
  m_aVisibleForFactions {
   "RHS_USAF"
  }
  m_iOrder 9
 }
}
