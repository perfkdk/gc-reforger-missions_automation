$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 ins_brief {
  coords 2136.614 17.842 6048.243
  m_sTitle "Mission overview"
  m_sTextData "We are a platoon(+) of Howler insurgents tasked with eliminating the remnants of US and Russian forces."
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  {
   $grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
    EnemyForces {
     coords 19.015 -2.268 13.71
     m_sTitle "Enemy forces"
     m_sTextData "A squad of US Army and Russian VDV equppied with 2020s gear including scopes and NVG. "\
     ""\
     "Unknown if they are working together."\
     ""
     m_aVisibleForFactions {
      "GC_INSURGENT"
     }
     m_iOrder 3
    }
    Situation {
     editor EntityEditorProps "{68E71EADCDF3603B}" {
     }
     coords 16.245 6.486 10.563
     m_sTitle "Situation"
     m_sTextData "The remanets of US and Russian forces have taken shelter at the marked construction site.We are ordered to kill them to show our strength to the world."\
     ""\
     "To make sure we succussed we have access to our brand new vehicles the HMMWVWBMPT and the HMMWVWBTRWT."
     m_aVisibleForFactions {
      "GC_INSURGENT"
     }
     m_iOrder 1
    }
    Mission_notes_READ {
     coords 35.26 4.218 24.273
     m_sTitle "Mission notes(READ)"
     m_sTextData "Setup timer is 5 min"\
     ""\
     "Insurgents win if they eliminate 90% of US and Russian forces."\
     ""\
     "Insurgents have a minor victory if they eliminate only 1 squad after 45 min."\
     ""\
     "Insurgents lose if they don't kill either in 45 min."\
     ""\
     "US win if they survive for 45 min."\
     ""\
     "RUS win if they survive for 45 min. "\
     ""\
     "US and Russian troops are allied together, although they don't need eachother to win."\
     ""
     m_aVisibleForFactions {
      "GC_INSURGENT"
     }
     m_iOrder 4
    }
    FriendlyForces {
     coords 0.057 -0.034 -0.562
     m_sTitle "Friendly forces"
     m_sTextData "A platoon(+) of insurgents with access to:"\
     ""\
     "-2 Humvees with a BTR turret welded on (capacity of 5)"\
     "-1 Humvee with a BMP turret welded on (capacity of 5)"\
     "-2 S1203 vans (capacity of 8)"\
     "-2 S105 cars (capacity of 4)"\
     "-2 Ural trucks (capacity of 15)"\
     "-2 M923A1 trucks (capacity of 15)"
     m_aVisibleForFactions {
      "GC_INSURGENT"
     }
     m_iOrder 2
    }
   }
  }
 }
 OVERVIEW {
  coords 3361.117 17.469 5920.063
  m_sTitle "Overview"
  m_sTextData "Stragglers of Russian and USA squad have fallen back to a construction site out of desperation to defend themselves from Howler insurgents and their \"new\" vehicles. "\
  ""\
  "Attackers pick time of day of early sunrise ,mid day or night."\
  ""\
  "Ratio is 1:1:4"\
  ""
  m_bEmptyFactionVisibility 1
 }
 OVERVIEW2 {
  coords 3356.86 17.52 5847.664
  m_sTitle "GM notes"
  m_sTextData "Besides time adjusting, no GMing needed unless for admin purposes."
  m_bEmptyFactionVisibility 1
  m_iOrder 1
 }
