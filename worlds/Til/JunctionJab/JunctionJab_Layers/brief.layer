$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 Brief_Overview {
  m_sTitle "Overview"
  m_sTextData "An East German motor rifle platoon attempts to seize the settlement of Hnevice in order to cut off the approach towards Luzohrad, supporting an imminent assault on the town."
  m_bEmptyFactionVisibility 1
 }
 Brief_Notes {
  coords 0 0 0
  m_sTitle "Notes"
  m_sTextData "5 minute setup timer restricting NVA"\
  ""\
  "End conditions:"\
  "- NVA Victory: 95% control over Hnevice for 1 minute"\
  "- CAF Victory: 80% NVA casualties, or 45 minutes pass"\
  ""\
  ""\
  "GMs must disable supply usage for the mortars ATM"
  m_bShowForAnyFaction 1
  m_iOrder 3
 }
 Brief_CAF {
  coords 0 0 0
  m_sTitle "Briefing"
  m_sTextData "<h1>SITUATION</h1>"\
  "a. Enemy Forces"\
  "East German motorized rifle regiment, preparing for an attack on Luzohrad"\
  ""\
  "b. Friendly Forces"\
  "Canadian light infantry battalion, defending Luzorad"\
  "One light infantry company (-), spread out across the blue area, tasked with defending the Hnevice and the approach towards Luzohrad, in order to maintain the flow of reinforcements and resupply into the town"\
  "Your section starts at Hnevice Military Base"\
  ""\
  "<h1>MISSION</h1>"\
  "Your section will support the defense of Hnevice by ambushing any enemies approaching Hnevice, and maneuvering/falling back as required"\
  "Intent is to either destroy the enemy force, or delay it by 45 minutes until reinforcements arrive"\
  ""\
  "<h1>SERVICE</h1>"\
  "Two unarmed M151 vehicles for transport"\
  "No resupply"
  m_aVisibleForFactions {
   "GC_CAF"
  }
  m_iOrder 1
 }
 Brief_NVA {
  coords 0 0 0
  m_sTitle "Briefing"
  m_sTextData "<h1>SITUATION</h1>"\
  "a. Enemy Forces"\
  "Canadian light infantry battalion, defending Luzorad"\
  "One light infantry company (-), spread out across the blue area, tasked with securing the approach towards Luzohrad by defending Hnevice"\
  ""\
  "b. Friendly Forces"\
  "East German motorized rifle regiment, preparing for an attack on Luzohrad"\
  "One motorized rifle platoon, tasked with supporting the main assault by seizing Hnevice, which would degrade the enemies ability to reinforce/resupply Luzohrad"\
  ""\
  "<h1>MISSION</h1>"\
  "Conduct an assault on Hnevice and take control of the settlement NLT than T+45m, bypassing enemy forces that are not in the vicinity of the chosen assault axis"\
  ""\
  "<h1>SUPPORT</h1>"\
  "2 mortar tubes, unlimited rounds"\
  "Forward observation group, mounted in SPW-40P2"\
  ""\
  "<h1>COMSIG</h1>"\
  "HQ, 1, 2, 3, 4 (FO), 5 (Mortars)"\
  "1 does not have a radio"\
  "4 and 5 have a radio backpack"
  m_aVisibleForFactions {
   "GC_NVA"
  }
  m_iOrder 1
 }
}