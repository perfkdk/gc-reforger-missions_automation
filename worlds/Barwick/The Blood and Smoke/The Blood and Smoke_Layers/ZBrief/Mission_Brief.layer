$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 Mission_Overview {
  coords 6413.948 38.442 2950.519
  m_sTitle "Mission Overview"
  m_sTextData "During a MediVac via BFV for a lightly wounded SEAL after a city security operation gone wrong, an IED is detonated causing a SEAL Team to go firm and the BFV MediVac to retreat out of the city. SEALs must survive and extract while under extreme threat, surrounded by the advancing and bloodthirsty Insurgent fighters."
  m_bEmptyFactionVisibility 1
  m_bShowForAnyFaction 1
 }
 Creator_Notes {
  coords 6413.952 74.893 2950.518
  m_sTitle "Creator Notes"
  m_sTextData "Thank you to the community's mission makers and modders who make the missions and resources for missions as well as giving me tips for mission making. Very special thanks to RedTheKnown for his help in teaching me how to make mission from the ground up with no prior knowledge myself, and with his help when I got stuck at times making this mission."
  m_bEmptyFactionVisibility 1
  m_bShowForAnyFaction 1
  m_iOrder 11
 }
