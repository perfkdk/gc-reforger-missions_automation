$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 Redfor_Situation {
  coords 6416.05 17.844 3196.44
  angles 0 -12.335 0
  m_sTitle "I. Situation"
  m_sTextData "	There was an explosion from an IED in the southern portion of the city. Some of the civilians said they saw the Americans go into a building in a compound somewhere in the SEARCH AREA."\
  ""\
  "	They also saw an American BFV drive away, out of the city going North. This is your chance! Get everyone from your neighborhoods and get ready to kill every last one of them."\
  " "\
  "	There is some stashed away RPG tubes and rockets in the Mosque for events like this, they could come in handy if the CO feels like they need them. "
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 1
 }
 Redfor_Enemy {
  coords 6435.542 18.224 3194.172
  angles 0 -12.335 0
  m_sTitle "III. Enemy Forces"
  m_sTextData "	The IED exploded near the SEARCH AREA. We can expect at least on group of Americans around there in the buildings held up after that explosion."\
  ""\
  "          -At least one possible injured group in the SEARCH AREA."\
  ""\
  "	  -Another 2 groups have been spotted SOMEWHERE ELSE in the South and West portions of the city."\
  ""\
  "	  -The IED hit an American BFV, we are sure they have more and will bring them in to stop us."\
  ""\
  "	  -Last known position of the BFVs was North of the city."\
  ""
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 3
 }
 Redfor_Friendlies {
  coords 6425.195 18.015 3195.538
  angles 0 -12.335 0
  m_sTitle "II. Friendly Forces"
  m_sTextData "	We have forces spread all across the town, and that IED woke them all up (AI). Our organized forces (Players) are now massing around the Northern neighborhoods of the city."\
  ""\
  "          -Sheikh Cell, 4 strong, command element. Centrally located."\
  ""\
  "          -Khaled Cell, 8 strong, MG and AR element, closest to SEARCH AREA."\
  ""\
  "	  -Ali Cell, 6 strong, RPG element, very limited on rockets, Northern-most cell."\
  ""\
  "	  -There is a cache with 2 RPG tubes and extra rockets with some RPG backpacks in the Mosque."\
  ""\
  "	  -There are alleyways between compounds and ramps between rooftops observed in the areas around the Mosque and South-East of the city. There are also ROADBLOCKS that cut off the entire road, keep these in mind and reference the markers on your maps."
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 2
 }
 Redfor_Mission {
  coords 6445.714 18.441 3192.369
  angles 0 -12.335 0
  m_sTitle "IV. Mission"
  m_sTextData "	We must kill all of them. Don't let them leave the city and crush them with our numbers."\
  ""\
  "          -Victory only comes with killing 90% of the Americans"\
  ""\
  "	  -If more than 10% Extract- we lose. Don't let them leave the city."
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 4
 }
}