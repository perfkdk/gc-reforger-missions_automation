$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 Redfor_Situation {
  coords 6416.05 17.844 3196.44
  angles 0 -12.335 0
  m_sTitle "I. Situation"
  m_sTextData "There was an explosion from an IED in the southern portion of the city. Some of the civilians said they saw the Americans go into a building in a compound somewhere in the SEARCH AREA. They also saw an American tank drive away with their American brothers. This is our chance! Get everyone from your neighborhood and get ready to kill every last one of them. We have stashed away RPG tubes and rockets in the mosque for events like this, they could come in handy if we feel like we need them."
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 1
 }
 Redfor_Enemy {
  coords 6435.542 18.224 3194.172
  angles 0 -12.335 0
  m_sTitle "III. Enemy Forces"
  m_sTextData "The IED exploded near the SEARCH AREA. We can expect at least on group of Americans around there in the buildings held up after that explosion."\
  ""\
  "          -At least one possibly injured group, and another 2 groups have been spotted elsewhere in the South and West portions of the city."\
  ""\
  "          -The IED hit an American BFV, we are sure they have more and will bring them in to stop us."
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 3
 }
 Redfor_Friendlies {
  coords 6425.195 18.015 3195.538
  angles 0 -12.335 0
  m_sTitle "II. Friendly Forces"
  m_sTextData "We have forces spread all across the town, and that IED woke them all up. Our organized forces are now massing around the Northern parts of the city."\
  ""\
  "          -Sheikh Cell, 4 strong, command element."\
  ""\
  "          -Khaled Cell, 8 strong, MG and AR element, closest to SEARCH AREA."\
  ""\
  "          -Ali Cell, 6 strong, RPG element, very limited on rockets."
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 2
 }
 Redfor_Mission {
  coords 6445.714 18.441 3192.369
  angles 0 -12.335 0
  m_sTitle "IV. Mission"
  m_sTextData "We must kill all of them. Don't let them leave the city and crush them with our numbers."\
  ""\
  "          -Victory only comes with killing 90% of the Americans"\
  ""\
  "          -If more than 10% Extract we lose. Don't let them leave the city."\
  ""
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 4
 }
}