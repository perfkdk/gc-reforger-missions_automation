PS_MissionDescription MISSIONNOTES : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 coords 3631.063 14.574 1216.845
 m_sTitle "Mission Notes"
 m_sTextData "<b>Mission Summary:</b>"\
 "US conducts a COY breach of a soviet mine and wire obstacle to sieze a trenchline on Torske Hill. "\
 ""\
 "<b>Trench building:</b>"\
 "Trench building time is reduced for the first 5 minutes. Only the AGS Team are permitted to add trenches for the purpose of concealing the AGS and utilizing it. "\
 ""\
 "<b>Map Customizing: </b>"\
 "This mission modifies some of the vegetation and treelines from the original basemap."\
 "Red areas on the map indicate locations where foliage, brush lines, or treelines have been removed."\
 "Green areas indicate locations where new foliage or treelines have been added."\
 ""\
 "<b>Setup timer:</b>"\
 "US: 5 Minutes"\
 ""\
 "<b>Endconditions</b>"\
 "BLUFOR (US) Victory Criteria:"\
 "- Major Victory: USSR attrited to 95% casualties. "\
 ""\
 "OPFOR (USSR) Victory Criteria:"\
 "- Major Victory: US attrited to 90% casualties."\
 "- Minor Victory: US unable to breach obstacle (Timelimit)"\
 ""\
 "<b>Timelimit:</b>"\
 "80 min"\
 ""\
 "GMs are permitted to create a breach in the obstacle for gameplay purposes, if BLUFOR are unable but this will result in automatic defeat for the US."\
 ""\
 "Mission by Blue , Trench by Lancer"\
 "Last updated: 2026-03-11"
 m_bEmptyFactionVisibility 1
 m_bShowForAnyFaction 1
 m_iOrder 10
}
