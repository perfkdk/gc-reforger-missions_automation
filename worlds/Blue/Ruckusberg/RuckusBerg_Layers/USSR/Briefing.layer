  m_sDescriptionLayout "{B6DE04F7CF7A95DA}UI/MissionDescription/DescriptionEditableScrollable.layout"
  m_sTextData "This is day 3 of advancing into Germany. The Enemy is currently retreating East to form defensive lines. Early this morning our BTN Recon PLT have located a massive ENY Convoy to the North retreating eastward. Our recon PLT made contact with the Convoy flank security but found it to be lacking in size."
  m_aVisibleForFactions {
   "USSR"
  }
  m_iOrder 1
 }
