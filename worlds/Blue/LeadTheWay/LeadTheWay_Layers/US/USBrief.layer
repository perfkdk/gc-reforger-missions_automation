$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 BRIEF6 {
  coords 4536.125 42.978 1334.951
  m_sTitle "6. BANGLORE USAGE"
  m_sTextData "To deploy the Bangalore:"\
  ""\
  "1. Place a Bangalore the same way you place Demo Charges by Equipping it through your hotbar or on any primary weapons slot and left clicking at the correct posittion."\
  ""\
  "2. When you’re near a placed Bangalore, a “Push” action will appear, hold F (Note: You must have bangalores in your inventory to do so)."\
  ""\
  "3. Each push will extend the Bangalore by adding a new section in front of the previous one. Continue deploying sections until the obstacle is fully bridged."\
  ""\
  "4. Once the full length of the Bangalore has been deployed, you can detonate it using either a timed fuse or a clacker on the first section you placed."\
  "Limitation: Only 6 Bangalores maximum ."
  m_aVisibleForFactions {
   "US"
  }
  m_iOrder 6
 }
 BRIEF1 {
  coords 4514.822 42.914 1339.047
  m_sTitle "1. SITUATION"
  m_sTextData "a. Enemy Forces"\
  "A Platoon of russian dismounted motor rifle regulars, entrenched in  a well prepared trench position with bunkers, indirect shelters and possibly a fall back trench. ENY has mined and placed fields to CANALIZE approaching elements."\
  ""\
  "b. Friendly Forces"\
  "- Our Company is assembly at area STEEL 0437 0147 "\
  "- Company Mortar B9 is located at 0437 0178"\
  "- Neighboring friendly elements maintain sector security but cannot provide immediate direct fire support inside the objective area."\
  ""\
  "c. Attachments / Detachments"\
  "- An Engineering Sqaud (1'4) has been attached to First Platoon to aid in breach of obstacles. "
  m_aVisibleForFactions {
   "US"
  }
  m_iOrder 1
 }
 BRIEF2 {
  coords 4517.678 43.034 1346.497
  m_sTitle "2. MISSION"
  m_sTextData "Bravo Company will SIEZE OBJ HILL NLT than 0800."
  m_aVisibleForFactions {
   "US"
  }
  m_iOrder 2
 }
 BRIEF3 {
  coords 4521.615 43.076 1350.828
  m_sTitle "3. EXECUTION"
  m_sTextData "As per Commander's Intent"\
  ""\
  "Mortar to Supress and provide concealment for Engineering Team to bridge a breach through ENY OBSTACLE IOT allow Bravo Company to Sieze OBJ HILL "
  m_aVisibleForFactions {
   "US"
  }
  m_iOrder 3
 }
 BRIEF4 {
  coords 4529.657 43.097 1351.475
  m_sTitle "4. SERVICE SUPPORT"
  m_sTextData "a. Logistics"\
  ""\
  "Ammo: COY Excess Ammunition in M113s, Engineer's M113 contains Bangalores"\
  ""\
  "Medical: On-site CLS."\
  ""\
  "Recovery: No vehicle recovery assets available inside AO."\
  ""\
  "b. Sustainment Notes"\
  ""\
  "Check for sufficient Bangalores to conduct a breach. "
  m_aVisibleForFactions {
   "US"
  }
  m_iOrder 4
 }
 BRIEF5 {
  coords 4533.034 43.128 1344.097
  m_sTitle "5. COMMAND & SIGNAL"
  m_sTextData "a. Command"\
  ""\
  "COY COMMANDER - Bulldog 6"\
  ""\
  "Succession: Bulldog 7 --> Bulldog 1'6 --> Bulldog 2'6"\
  ""\
  "b. Signal"\
  ""\
  "BULLDOG COY Net: CH48 Mhz"\
  "BULLDOG FIRES NET: CH50 Mhz"\
  "BULLDOG 1st PLT: CH 48.5 Mhz"\
  "BULLDOG 2nd PLT: CH 49 Mhz"
