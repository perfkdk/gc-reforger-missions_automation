$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 SituationRebel {
  coords 3561.957 264.055 4179.146
  m_sTitle "I. Situation"
  m_sTextData "As part of a larger offensive against the Takistan army a TKA infantry company has been encircled in the town of Chak Chak at grid 044006. They occupy a number of defensive positions in the town, and are now awaiting helecopter extraction which is expected to arrive in about 50 minuets. We have been tasked with eliminating this force before it can be withdrawn."\
  ""\
  ""
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 1
 }
 FriendlyForcesRebel {
  coords 3561.685 263.752 4180.775
  m_sTitle "II. Friendly Forces"
  m_sTextData "1x infantry company augmented with unarmed motorized transport, heavy tripod weapons, and VBIEDs. Currently located in the north of the AO."\
  ""\
  "Wearing a wide range of camo patterns and colors, with head wraps and soft caps. Armed with AKs and other Soviet weapons."
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 2
 }
 FortificationsRebel {
  coords 3555.269 263.366 4177.593
  m_sTitle "V. Enemy Forifications"
  m_sTextData "Chak Chak has a number of defensive positions."\
  ""\
  "There is a set of partially constructed fortifications consisting of sandbag bunkers and trenches on the high ground in the middle of town. Marked as \"Fortifications\"."\
  ""\
  "There is a fortified compound on the south east side of town. Marked as \"MainComp\"."\
  ""\
  "There is a smaller fortified compound on the south west side of town. Marked as \"WestComp\"."\
  ""\
  "There are two roadblocks made of barbed wire and dragonsteeth, which block the road at the east and west sides of town. Marked as \"RoadBlock\"."
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 5
 }
 Vics_and_EquipmentRebel {
  coords 3559.594 263.575 4180.146
  m_sTitle "III. Vehicles and Equipment"
  m_sTextData "We have preppositioned a number of vehicles for the attack. Each start point has 4x UAZ vans, 4x Ural trucks, and 1x Ural VBIED"\
  ""\
  "We have a cache of extra supplies at our inital staging area. It is a stack of green crates located near the road."\
  ""\
  "We have 2x 6T7 NSV HMG which are located in the cache at the staging area."
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 3
 }
 EnemyForcesRebel {
  coords 3560.171 263.651 4180.155
  m_sTitle "IV. Enemy Forces"
  m_sTextData "1x reduced infantry company located in the fortified town of Chak Chak. With 2x M151A2 (Jeep) with M2HB."\
  ""\
  "Wearing olive green fatigues with soviet helmets, armed with Soviet weapons."
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 4
 }
 Deployment {
  coords 3563.293 264.119 4180.013
  m_sTitle "VI. Deployment"
  m_sTextData "After the setup timer has ended rebel forces will be able to teleport via the doors at their staging area to the north, east, or west start points. Vehicles are present at each start point, and any combination of start points can be used."\
  ""\
  ""
  m_aVisibleForFactions {
   "GC_INSURGENT"
  }
  m_iOrder 6
 }
}