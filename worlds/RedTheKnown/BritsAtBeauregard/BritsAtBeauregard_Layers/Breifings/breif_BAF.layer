$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 A_Situation_BAF {
  coords 2914.388 62.7 1917.74
  m_sTitle "I. Situation"
  m_sTextData "Just under an hour ago the town of Beauregard and its vital dock were sized by a Russian motorized naval infantry force rapidly landed via hovercraft. Further Russian forces equiped with MBTs and IFVs are expect to be landed at their location within the next hour, the town must be captured before any such reinforcements can arrive."
  m_aVisibleForFactions {
   "UK"
  }
 }
 C_FriendlyForces_UK {
  coords 2904.489 63.313 1904.979
  m_sTitle "III. Friendly Forces"
  m_sTextData "1x British motorized light infantry company of reduced strength, with attched battery of 2x 81mm mortars. Currently located at the staging area in the town of Arleville."
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 2
 }
 D_EnemyForces_UK {
  coords 2926.015 62.75 1904.571
  m_sTitle "IV. Enemy Forces"
  m_sTextData "1x Russian motorized naval infantry platoon. Currently located somewhere in the town of Beauregard to the north."\
  ""\
  "Vehicles:"\
  "	4x PKM armed UAZ469,"\
  "	6x unarmed open-top UAZ469,\"\"
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 3
 }
 E_VicsAndEquipment_UK {
  coords 2932.577 62.319 1908.936
  m_sTitle "V. Vics and Equipment"
  m_sTextData "We have a number of vehicle at our staging area, these vehicle have already been loaded with additional ammunition and supplies."\
  "	7x unarmed camo-net land rovers,"\
  "	2x recce camo-net land rovers armed with 1x M2HB and 1x GPMG,"\
  "	2x recce camo-net land rovers armed 2x GPMG."\
  ""\
  "We have a cache of extra supplies at our inital staging area. It is a stack of green crates located next to the flag. This cache contains: hand flares, extra wrenches."
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 4
 }
 F_MortarBattery_UK {
  coords 2918.025 63.124 1895.898
  m_sTitle "VI. M252 Mortar Battery"
  m_sTextData "We have a local mortar battery consisting of 2x M252 81mm mortars. They are located at a prepared firing position along with their supply of ammunition down hill from the staging area. This area has been marked with a blue circle labled \"Mortars\". This mark is located directly between the two mortars, and is a reliable targeting referance."\
  ""\
  "Battery ammuniton supply: 120x HE, 50x Illum, 50x Smoke"
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 5
 }
 H_MineThreat_UK {
  coords 2915.84 63.143 1897.595
  m_sTitle "VIII. Mine Threat (READ)"
  m_sTextData "Intercepted Russian radio communications have alerted us to a potential anti-tank mine threat, estimated at 10 - 15 TM62M mines. While it is not guaranteed this supply of anti-tank mines will be utilized it is highly probable. "
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 7
 }
 G_ComSig_UK {
  coords 2921.833 63.068 1891.761
  m_sTitle "VII. Command & Signal"
  m_sTextData "Company net: 48.0 Mhz"\
  "11: Platoon net: 47.5 Mhz"\
  "12: Platoon net: 47.0 Mhz"\
  "Mortar Fires net: 48.2 Mhz"\
  "Backup net 1: 51.1 Mhz"\
  "Backup net 2: 46.6 Mhz"\
  ""\
  "CO: 1A"\
  "2IC: 1B"\
  "Mortar Battery: Basher"\
  "Company Fire Controller: Jester"\
  ""\
  "Challenge A:"\
  "	Call - Oak"\
  "	 Response - Reed"\
  ""\
  "Challange B:"\
  "	Call - Maroon"\
  "	Response - Warboat"\
  ""\
  "Challange C:"\
  "	Call - Harp"\
  "	Responce - Balance"
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 6
 }
 B_Mission_BAF {
  coords 2951.333 62.211 1909.498
  m_sTitle "II. Mission"
  m_sTextData "In order to achive victory we must either take control Beauregard or eleminate 95% of the defending Russian force before reinforcements arrive in roughly 45 minuets. The center of Beauregard must be captured and held for at least 5 minuets to take control of the town, it has been marked as \"Town Center\"."
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 1
 }
}