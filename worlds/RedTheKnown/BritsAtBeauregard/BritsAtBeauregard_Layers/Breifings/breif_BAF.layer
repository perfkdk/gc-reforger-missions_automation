$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 Situation_BAF {
  coords 2914.388 62.7 1917.74
  m_sTitle "I. Situation"
  m_sTextData "Just under and hour ago the town of Beauregard and its vital dock were sized by a Russian motorized naval infantry force rapidly landed via hovercraft. Further Russian forces are expect to land at their location within the next hour, the town must before any such reinforcements can arrive."\
  ""\
  "The center of Beauregard is what must be captured to ensure control of the town. If we capture and hold that area for at least 5 minuets then we will secure victory. This area is marked as \"Town Center\"."
  m_aVisibleForFactions {
   "UK"
  }
 }
 FriendlyForces_UK {
  coords 2904.489 63.313 1904.979
  m_sTitle "III. Friendly Forces"
  m_sTextData "1x Brtish motorized light infantry platoon. Augmented with a battery of 2x 81mm mortars. Currently located at the staging area in the town of Arleville."
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 1
 }
 EnemyForces_UK {
  coords 2926.015 62.75 1904.571
  m_sTitle "IV.  Friendly Forces"
  m_sTextData "1x Russian motorized naval infantry platoon. Augmented with: 1x NSV HMG, dedicated recon teams, a suppy of anti-tank mines, 2x armed PKM UAZs, multiple other unarmed light vehicles. Currently located somewhere in the town of Beauregard to the north."
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 3
 }
 VicsAndEquipment_UK {
  coords 2932.577 62.319 1908.936
  m_sTitle "III. Vics and Equipment"
  m_sTextData "We have a number of vehicle at our staging area: 6x unarmed camo-net land rovers, 2x recce camo-net land rovers each armed with a M2HB and  GPMG. These vehicle have already been loaded with additional ammunition and supplies."\
  ""\
  "We have a cache of extra supplies at our inital staging area. It is a stack of green crates located next to the flag. This cache contains: hand flares, wrenches."
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 2
 }
 MortarBattery_UK {
  coords 2918.025 63.124 1895.898
  m_sTitle "V. M252 Mortar Battery"
  m_sTextData "We have a local mortar battery consisting of 2x M252 81mm mortars. They are located at a prepared firing position along with their supply of ammunition down hill from the staging area. This area has been marked with a blue circle labled \"Mortars\". This mark has been placed directly between the two mortars to be used as a targeting referance."
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 4
 }
 MineThreat_UK {
  coords 2915.84 63.143 1897.595
  m_sTitle "VI. Mine Threat (READ)"
  m_sTextData "Recently intercepted Russian radio communications have alerted us to the a potential anti-tank mine threat. While it is not guaranteed"\
  "the Russian force we are facing will utilize their supply of anti-tank mines it is highly probable they will."
  m_aVisibleForFactions {
   "UK"
  }
  m_iOrder 4
 }
}