$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 {
  coords 5034.509 251.545 9764.378
  m_sTitle "SITUATION"
  m_sTextData "<b>Date:</b> 2019-08-17"\
  "<b>Location:</b> Javory, Bystrany"\
  ""\
  "Our cell is currently operating within and around Javory village, maintaining a low-profile presence among civilian infrastructure. The area is being used as a temporary logistics base to support our ongoing operations in the region."\
  ""\
  "Recent activity indicates increased pressure from government forces. Our civilian informants in nearby areas suggest a possible search operation may be imminent."
  m_aVisibleForFactions {
   "FIA"
  }
 }
 {
  coords 5033.961 251.52 9765.55
  m_sTitle "MISSION"
  m_sTextData "FIA elements in Javory are tasked to:"\
  ""\
  "- <b>Defend 2x ammunition caches.</b>"\
  ""\
  "- Eliminate any and all attacking enemy forces."
  m_aVisibleForFactions {
   "FIA"
  }
 }
 {
  coords 5033.138 251.482 9767.377
  m_sTitle "FRIENDLY FORCES"
  m_sTextData "FIA fighters are equipped with a mixture M81/OD camouflage. Most of our soldiers are supplied with modernized VZ-58 style rifles."\
  ""\
  "We also possess:"\
  ""\
  "- 1x MAT team"\
  ""\
  "- 1x MMG team"
  m_aVisibleForFactions {
   "FIA"
  }
 }
 {
  coords 5032.124 251.447 9769.027
  m_sTitle "ENEMY FORCES"
  m_sTextData "Other nearby FIA cells have reported being attacked by a platoon sized AFRF light motorized infantry tactical detachment.  "\
  ""\
  "Our friends tell us that there may be a special forces element attached to said platoon."\
  ""\
  "Civilian informants positioned along the eastern MSR have told us that a convoy of GAZ Tigr vehicles with armed men inside has just passed them by. They are probably here for us."
  m_aVisibleForFactions {
   "FIA"
  }
 }
 {
  coords 5030.847 251.413 9770.541
  m_sTitle "ADMIN & SUPPLY"
  m_sTextData "FIA soldiers are equipped with their standard combat load."\
  ""\
  "Located inside Cache A building are:"\
  ""\
  "- 200x sandbags"\
  ""\
  "- 5x backpacks"
  m_aVisibleForFactions {
   "FIA"
  }
 }
 {
  coords 5029.563 251.376 9772.146
  m_sTitle "END CONDITIONS"
  m_sTextData "- Both ammunition caches located and destroyed."\
  ""\
  "- Time limit exhausted."\
  ""\
  "- 85% of AFRF/SSO forces eliminated."\
  ""\
  "- 95% of FIA forces eliminated."
  m_aVisibleForFactions {
   "FIA"
  }
 }
 {
  coords 5027.8 251.339 9773.993
  m_sTitle "MM NOTES"
  m_sTextData "<b>Time limit:</b> 60 minutes or until it gets boring."\
  ""\
  "You have been given sandbags, but you are <b>not allowed to place them in ways that would block people from accessing the cache locations.</b>"\
  ""\
  "Cache A is located inside a farm shed next to your spawn."\
  ""\
  "Cache B is located on the second floor of the church."
  m_aVisibleForFactions {
   "FIA"
  }
 }
}
