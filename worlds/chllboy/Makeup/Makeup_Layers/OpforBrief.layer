$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 {
  coords 6064.386 233.767 9495.153
  m_sTitle "SITUATION"
  m_sTextData "<b>Date:</b> 2019-08-17"\
  "<b>Location:</b> Javory, Bystrany"\
  ""\
  "Armed terrorist group known as the \"FIA\" has intensified it's operations in the Bystrany region. Intelligence confirms the presence of two ammunition caches, vital to their activities, within or on the outskirts of Javory village."\
  ""\
  "A mobile, reinforced platoon-sized tactical detachment has been deployed under battalion orders to exploit time-sensitive intelligence and eliminate key FIA logistical assets before they can be relocated."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 1
 }
 {
  coords 6066.516 233.6 9495.186
  m_sTitle "MISSION"
  m_sTextData "Conduct a search and destroy operation in and around Javory in order to:"\
  ""\
  "- <b>Locate and destroy 2x ammunition caches.</b>"
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 2
 }
 {
  coords 6069.205 233.284 9495.126
  m_sTitle "FRIENDLY FORCES"
  m_sTextData "A mixed, platoon-sized tactical detachment composed of conventional AFRF rifle elements reinforced with SSO teams. "\
  ""\
  "The unit is equipped with GAZ Tigr vehicles for mobility and local fire support. "
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 3
 }
 {
  coords 6071.499 232.991 9495.293
  m_sTitle "ENEMY FORCES"
  m_sTextData "Intelligence estimates around 18-27 well trained and equipped FIA fighters to have taken up defences inside and around the village."\
  ""\
  "Enemy fighters have been spotted using <b>M81/OD</b> camouflage patterns, likely to be equipped with modernized VZ-58 style rifles and limited AT and MMG support. "
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 4
 }
 {
  coords 6073.699 232.952 9495.24
  m_sTitle "ADMIN & SUPPLY"
  m_sTextData "AFRF and SSO soldiers are equipped with their standard combat load."\
  ""\
  "Tactical detachment currently has:"\
  ""\
  "- 2x GAZ Tigr armed with Kord heavy machine guns"\
  ""\
  "- 2x GAZ Tigr armed with PKP machine guns"\
  ""\
  "- 7x GAZ Tigr unarmed transport vehicles"
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 5
 }
 {
  coords 6076.701 232.894 9495.179
  m_sTitle "END CONDITIONS"
  m_sTextData "- Both ammunition caches located and destroyed."\
  ""\
  "- Time limit exhausted."\
  ""\
  "- 85% of AFRF/SSO forces eliminated."\
  ""\
  "- 95% of FIA forces eliminated."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 6
 }
 {
  coords 6080.71 232.644 9495.012
  m_sTitle "MM NOTES"
  m_sTextData "<b>Time limit:</b> 60 minutes or until it gets boring."\
  ""\
  "Caches look like dark green stacks of weapon/ammo boxes."
  m_aVisibleForFactions {
   "RHS_AFRF"
  }
  m_iOrder 7
 }
}
