PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 coords 3355.885 310.616 450.373
 m_sTitle "SITUATION"
 m_sTextData "Two months after insurgents used locally built FPV drones to successfully attack U.S. forces, American intelligence identified a concealed drone manufacturing site near Gulahy Shal as the source. A platoon from the 75th Ranger Regiment is now preparing a night air assault to destroy the facility, gather intelligence, and prevent further attacks. Meanwhile, approximately 30 insurgents at the compound, aware they may be targeted, are prepared to defend the site."\
 ""\
 "<b>RATIO: 1:1.5</b>"
 m_bEmptyFactionVisibility 1
}