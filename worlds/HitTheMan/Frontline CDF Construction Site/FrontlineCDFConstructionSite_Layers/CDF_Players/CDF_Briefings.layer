$grp PS_MissionDescription : "{3136BE42592F3B1B}PrefabsEditable/MissionDescription/EditableMissionDescription.et" {
 OPF_Briefing_2_Mission {
  coords 5810.876 272.451 10244.802
  m_sTitle "II. Mission: (Must Read)"
  m_sTextData "<h2>II: Mission</h2>"\
  "(Do Not Fire Mortars During The Setup Timer)"\
  ""\
  "Push up and secure the marked construction site."\
  ""\
  "RECON unit can move during setup timer, use this to locate hostile forces, skirmish with them or simply observe."\
  ""\
  "The enemy likely have heavily trenches areas and setup MG Nests, try and locate them before comitting to a attack axis."\
  ""\
  "Highly recommended to use the mortar to lay down a smoke mission, use the BMP-1ZDs to laydown heavy supresssion as well, before committing the main force body."
  m_aVisibleForFactions {
   "GC_CDF"
  }
  m_iOrder 4
 }
 OPF_Briefing_3_Sustainment {
  coords 5811.303 272.534 10244.736
  m_sTitle "III. Sustainment:"
  m_sTextData "<h2>III: Sustainment</h2>"\
  "<b>a. SOP Variations</b>"\
  "Dress: Standard CDF Uniform"\
  "Equipment: Standard CDF Loadout"\
  ""\
  "<b>b. Logistical Support:</b>"\
  "Replen Plan: None for 24h."\
  "Ammunition: Each man carries his own ammunition."\
  "IPE: Helmets and body armour are to be worn at all times."\
  ""\
  "Each M113 carries:"\
  "- 20x Bandages"\
  "- 60x AK 30rnd Magazines"\
  "- 10x 100rnd PKM Boxes"\
  ""\
  "<b>c. Medical:</b>"\
  "Location: Company Aid Post is to be setup by company medics."\
  "CASEVAC: By foot or with company asset like the Ambulance IF there are any."\
  "Plan: Set up a casualty collection point and extract casualties to this point."\
  "Stretchers: None"\
  "Med Packs: Company medpack carried by company medic."\
  "Morphine: Every soldier carries 1+ stick of morphine."\
  ""\
  "<b>d. Vehicles:</b>"\
  "2x BMP-1ZDs"\
  "4x M113s"
  m_aVisibleForFactions {
   "GC_CDF"
  }
  m_iOrder 6
 }
 OPF_Briefing_4_CommandnSignal {
  coords 5811.692 272.468 10245.123
  m_sTitle "IV. Command & Signals:"
  m_sTextData "<h2>IV. Command & Signal:</h2>"\
  "<b>I. Chain of Command:</b>"\
  "240, 241, 242, etc."\
  ""\
  "<b>II. Callsigns:</b>"\
  "1st Platoon HQ ------------------- 240"\
  "1st Squad --------------------------- 241"\
  "2nd Squad -------------------------- 242"\
  "3rd Squad --------------------------- 243"\
  "4th Squad --------------------------- 244"\
  ""\
  "1st Recon Team ------------------ 251"\
  "2nd Recon Team ------------------ 252"\
  ""\
  "1st BMP-1ZD ---------------------------- 321v"\
  "2nd BMP-1ZD ---------------------------- 322v"\
  ""\
  "Mortar Crew --------------------------- 512"\
  ""\
  "<b>III. Frequencies:</b>"\
  "Platoons Net ----------- 48.00Mhz"\
  "Mortar Net ------------- 49.00Mhz"
  m_aVisibleForFactions {
   "GC_CDF"
  }
  m_iOrder 7
 }
}