  "2nd Squad -------------------------- 415"\
  "3rd Squad --------------------------- 416"\
  ""\
  "1st BMP-1ZD ---------------------------- 431v"\
  "2nd BMP-1ZD ---------------------------- 432v"\
  ""\
  "<b>III. Frequencies:</b>"\
  "Company Net ----------- 48.00Mhz"
  m_aVisibleForFactions {
   "USSR"
  }
  m_iOrder 7
 }
